  <!-- スクリプト群（is:inlineを指定して元のまま動作させます） -->
  <script src="https://code.jquery.com/jquery-3.7.0.min.js" is:inline></script>
  <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js" is:inline></script>

  <script is:inline>
    // DataTablesの初期化
    $(document).ready(function () {
      $('#gymTable').DataTable({
        language: {
          url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/ja.json"
        },
        order: [[0, 'asc']],
        pageLength: 10,
        searching: true,
        autoWidth: false
      });
    });

    // 目次のスクロールとアクティブ状態の制御
    document.querySelectorAll('.nav-link, .nav-sub-link').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        const href = this.getAttribute('href');
        if (href.startsWith('#')) {
          e.preventDefault();
          const targetId = href.substring(1);
          const targetElement = document.getElementById(targetId);

          if (targetElement) {
            const yOffset = -20;
            const y = targetElement.getBoundingClientRect().top + window.pageYOffset + yOffset;
            window.scrollTo({ top: y, behavior: 'smooth' });
          }
        }
      });
    });

    const sections = document.querySelectorAll('[id^="section-"], [id^="sub-"]');
    const navLinks = document.querySelectorAll('.nav-link, .nav-sub-link');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === '#' + entry.target.id) {
              link.classList.add('active');
            }
          });
        }
      });
    }, { rootMargin: '-10% 0px -80% 0px' });

    sections.forEach(section => observer.observe(section));
  </script>
