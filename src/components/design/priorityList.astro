---
<ol class="priority-list">
  <slot />
</ol>

<style is:global>
  .priority-list {
    counter-reset: priority-counter;
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
  }
  .priority-list li {
    counter-increment: priority-counter;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.4rem 0;
    font-size: 0.93rem;
  }
  .priority-list li::before {
    content: "第" counter(priority-counter) "優先";
    background-color: #ede9fe;
    color: #5b21b6;
    border-radius: 12px;
    padding: 0.1rem 0.6rem;
    font-size: 0.75rem;
    font-weight: bold;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>